#include <lmic.h>
#include <hal/hal.h>
#include <SPI.h>

// OTAA Keys (Einzigartig pro Node - generiert in ChirpStack)
static const u1_t PROGMEM APPEUI[8]={ 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00 };
static const u1_t PROGMEM DEVEUI[8]={ 0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07, 0x08 };
static const u1_t PROGMEM APPKEY[16]={ 0xXX... }; // Dein AES128 Key

void os_getArtEui (u1_t* buf) { memcpy_P(buf, APPEUI, 8); }
void os_getDevEui (u1_t* buf) { memcpy_P(buf, DEVEUI, 8); }
void os_getDevKey (u1_t* buf) { memcpy_P(buf, APPKEY, 16); }

// Payload Buffer (8 Byte gemäß Spezifikation)
static uint8_t mydata[8];
static osjob_t sendjob;

void do_send(osjob_t* j){
    if (LMIC.opmode & OP_TXRXPEND) {
        Serial.println(F("TX pending, skipping..."));
    } else {
        // 1. Sensoren auslesen (Beispielwerte)
        uint16_t ph = 651;        // 6.51 * 100
        uint16_t moisture = 42;    // 42%
        int16_t temp = 1850;      // 18.50 * 100
        uint16_t ec = 320;        // 320 uS/cm

        // 2. Packen in 8 Byte Big-Endian
        mydata[0] = ph >> 8;     mydata[1] = ph & 0xFF;
        mydata[2] = moisture >> 8; mydata[3] = moisture & 0xFF;
        mydata[4] = temp >> 8;   mydata[5] = temp & 0xFF;
        mydata[6] = ec >> 8;     mydata[7] = ec & 0xFF;

        // 3. Senden (Port 1, unconfirmed für Low Airtime)
        LMIC_setTxData2(1, mydata, sizeof(mydata), 0);
        Serial.println(F("Packet queued"));
    }
}

void setup() {
    Serial.begin(115200);
    os_init();
    LMIC_reset();
    do_send(&sendjob);
}

void loop() {
    os_runloop_once();
    // Nach erfolgreichem TX: ESP32 in Deep Sleep für 15 Min
}
